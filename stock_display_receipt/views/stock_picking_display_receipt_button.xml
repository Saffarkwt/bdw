<odoo>
  <record id="view_picking_form_display_receipt" model="ir.ui.view">
    <field name="name">stock.picking.display.receipt.button</field>
    <field name="model">stock.picking</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="arch" type="xml">
      <xpath expr="//header" position="inside">
        <button name="print_display_receipt"
                type="object"
                string="طباعة سند الاستلام"
                class="btn-primary"/>
      </xpath>
    </field>
  </record>
</odoo>
